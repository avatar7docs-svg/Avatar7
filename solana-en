<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>S7UE · Seven Unlock Engine — ARGI Architecture | AVATAR7</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Syne:wght@400;700;800&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg:        #060608;
      --bg2:       #0c0c12;
      --panel:     #0f0f18;
      --border:    #1e1e2e;
      --purple:    #8e44ad;
      --purple2:   #a855f7;
      --violet:    #6d28d9;
      --gold:      #c9a84c;
      --amber:     #d35400;
      --text:      #d0d0e0;
      --muted:     #5a5a7a;
      --bright:    #f0eeff;
      --green:     #22c55e;
      --mono:      'Share Tech Mono', monospace;
      --sans:      'Syne', sans-serif;
      --code:      'Space Mono', monospace;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--mono);
      overflow-x: hidden;
      cursor: crosshair;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none; z-index: 9999; opacity: .35;
    }

    body::after {
      content: '';
      position: fixed; inset: 0;
      background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,.07) 2px, rgba(0,0,0,.07) 4px);
      pointer-events: none; z-index: 9998;
    }

    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 18px 48px;
      background: rgba(6,6,8,.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }

    .nav-logo {
      font-family: var(--sans);
      font-weight: 800;
      font-size: 1.1rem;
      color: var(--bright);
      letter-spacing: .12em;
      text-transform: uppercase;
    }
    .nav-logo span { color: var(--purple2); }

    .nav-tag {
      font-size: .65rem;
      color: var(--muted);
      letter-spacing: .2em;
    }

    .nav-status {
      display: flex; align-items: center; gap: 8px;
      font-size: .65rem; color: var(--green); letter-spacing: .15em;
    }
    .nav-status::before {
      content: '';
      width: 6px; height: 6px;
      background: var(--green);
      border-radius: 50%;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%,100% { opacity: 1; }
      50% { opacity: .3; }
    }

    .hero {
      min-height: 100vh;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 120px 48px 80px;
      position: relative;
      overflow: hidden;
    }

    .hero-grid {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(142,68,173,.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(142,68,173,.06) 1px, transparent 1px);
      background-size: 60px 60px;
      animation: gridshift 20s linear infinite;
    }

    @keyframes gridshift {
      from { background-position: 0 0; }
      to   { background-position: 60px 60px; }
    }

    .hero-glow {
      position: absolute;
      width: 700px; height: 700px;
      background: radial-gradient(circle, rgba(142,68,173,.15) 0%, transparent 70%);
      top: 50%; left: 50%; transform: translate(-50%,-50%);
      pointer-events: none;
    }

    .hero-eyebrow {
      font-size: .65rem;
      letter-spacing: .3em;
      color: var(--purple2);
      margin-bottom: 24px;
      text-transform: uppercase;
      opacity: 0;
      animation: fadein .6s .3s forwards;
    }

    .hero-title {
      font-family: var(--sans);
      font-size: clamp(3rem, 8vw, 7rem);
      font-weight: 800;
      line-height: 1;
      text-align: center;
      color: var(--bright);
      text-transform: uppercase;
      letter-spacing: -.01em;
      position: relative;
      opacity: 0;
      animation: fadein .8s .5s forwards;
    }

    .hero-title .accent { color: var(--purple2); }
    .hero-title .line2 {
      display: block;
      font-size: .38em;
      letter-spacing: .25em;
      color: var(--muted);
      margin-top: 8px;
      font-weight: 400;
    }

    .hero-sub {
      margin-top: 32px;
      font-size: .8rem;
      color: var(--muted);
      letter-spacing: .1em;
      text-align: center;
      max-width: 560px;
      line-height: 1.9;
      opacity: 0;
      animation: fadein .8s .8s forwards;
    }

    .hero-badges {
      display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;
      margin-top: 32px;
      opacity: 0;
      animation: fadein .8s 1s forwards;
    }

    .badge {
      padding: 5px 14px;
      border: 1px solid var(--border);
      font-size: .6rem;
      letter-spacing: .2em;
      color: var(--muted);
      text-transform: uppercase;
    }
    .badge.purple { border-color: var(--purple); color: var(--purple2); }
    .badge.gold { border-color: var(--gold); color: var(--gold); }

    .terminal-wrap {
      margin-top: 56px;
      width: 100%; max-width: 720px;
      opacity: 0;
      animation: fadein .8s 1.2s forwards;
    }

    .terminal {
      background: #080810;
      border: 1px solid var(--border);
      padding: 24px 28px;
      font-family: var(--code);
      font-size: .72rem;
      line-height: 2;
    }

    .terminal-bar {
      display: flex; gap: 6px; margin-bottom: 16px;
    }
    .dot { width: 10px; height: 10px; border-radius: 50%; }
    .dot.r { background: #ff5f57; }
    .dot.y { background: #ffbd2e; }
    .dot.g { background: #28c940; }

    .t-prompt { color: var(--purple2); }
    .t-cmd    { color: var(--bright); }
    .t-out    { color: var(--muted); }
    .t-val    { color: var(--gold); }
    .t-ok     { color: var(--green); }
    .t-err    { color: var(--amber); }
    .t-cursor { display: inline-block; width: 8px; height: 14px; background: var(--purple2); animation: blink 1s step-end infinite; vertical-align: middle; }

    @keyframes blink { 50% { opacity: 0; } }

    .section-wrap {
      max-width: 1100px;
      margin: 0 auto;
      padding: 100px 48px;
    }

    .section-label {
      font-size: .6rem;
      letter-spacing: .35em;
      color: var(--purple2);
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .section-title {
      font-family: var(--sans);
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 800;
      color: var(--bright);
      text-transform: uppercase;
      margin-bottom: 48px;
      letter-spacing: -.01em;
    }

    .section-title span { color: var(--purple2); }

    .divider {
      border: none;
      border-top: 1px solid var(--border);
      margin: 0 48px;
    }

    .spec-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
    }

    .spec-card {
      background: var(--panel);
      padding: 32px 28px;
      transition: background .2s;
    }
    .spec-card:hover { background: #14141f; }

    .spec-card-num {
      font-size: .6rem;
      color: var(--muted);
      letter-spacing: .2em;
      margin-bottom: 16px;
    }

    .spec-card-title {
      font-family: var(--sans);
      font-size: 1rem;
      font-weight: 700;
      color: var(--bright);
      text-transform: uppercase;
      letter-spacing: .05em;
      margin-bottom: 12px;
    }

    .spec-card-body {
      font-size: .72rem;
      color: var(--muted);
      line-height: 1.9;
    }

    .spec-card-body .hi  { color: var(--amber); font-weight: bold; }
    .spec-card-body .hi2 { color: var(--purple2); }
    .spec-card-body .hi3 { color: var(--gold); }

    .formula-block {
      margin: 48px 0;
      border: 1px solid var(--purple);
      padding: 32px 36px;
      position: relative;
      background: rgba(142,68,173,.04);
    }

    .formula-block::before {
      content: 'CRITICAL FORMULA';
      position: absolute; top: -9px; left: 24px;
      background: var(--bg);
      padding: 0 10px;
      font-size: .55rem;
      color: var(--purple2);
      letter-spacing: .25em;
    }

    .formula {
      font-family: var(--code);
      font-size: 1.5rem;
      color: var(--amber);
      letter-spacing: .05em;
      margin-bottom: 12px;
    }

    .formula-desc {
      font-size: .7rem;
      color: var(--muted);
      line-height: 1.8;
    }

    .spec-table {
      width: 100%;
      border-collapse: collapse;
      margin: 32px 0;
      font-size: .72rem;
    }

    .spec-table th {
      background: var(--border);
      color: var(--muted);
      font-family: var(--mono);
      letter-spacing: .15em;
      text-transform: uppercase;
      font-size: .6rem;
      padding: 14px 18px;
      text-align: left;
      border: 1px solid #1a1a2a;
    }

    .spec-table td {
      padding: 14px 18px;
      border: 1px solid #1a1a2a;
      color: var(--text);
      vertical-align: top;
    }

    .spec-table tr:hover td { background: rgba(142,68,173,.04); }
    .spec-table .key { color: var(--purple2); }
    .spec-table .val { color: var(--bright); }

    .diagram-wrap {
      display: flex;
      align-items: center;
      gap: 60px;
      margin: 48px 0;
      flex-wrap: wrap;
    }

    .diagram-svg { flex: 0 0 auto; }
    .diagram-legend { flex: 1; min-width: 240px; }

    .legend-item {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      margin-bottom: 20px;
    }

    .legend-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      margin-top: 5px;
      flex-shrink: 0;
    }

    .legend-label {
      font-size: .68rem;
      color: var(--muted);
      line-height: 1.7;
    }

    .legend-label strong {
      color: var(--bright);
      display: block;
      margin-bottom: 3px;
      font-family: var(--sans);
      font-size: .75rem;
      text-transform: uppercase;
      letter-spacing: .08em;
    }

    .value-strip {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      margin: 48px 0;
    }

    .value-item {
      background: var(--panel);
      padding: 28px 24px;
    }

    .value-icon {
      font-size: 1.4rem;
      margin-bottom: 14px;
    }

    .value-name {
      font-family: var(--sans);
      font-size: .8rem;
      font-weight: 700;
      color: var(--bright);
      text-transform: uppercase;
      letter-spacing: .08em;
      margin-bottom: 8px;
    }

    .value-desc {
      font-size: .65rem;
      color: var(--muted);
      line-height: 1.8;
    }

    .phase-row {
      display: grid;
      grid-template-columns: 80px 1fr 1fr;
      gap: 1px;
      background: var(--border);
      border-bottom: 1px solid var(--border);
    }

    .phase-row:first-child { border-top: 1px solid var(--border); }

    .phase-cell {
      background: var(--panel);
      padding: 20px 24px;
      font-size: .7rem;
    }

    .phase-cell.head {
      background: var(--border);
      color: var(--muted);
      font-size: .58rem;
      letter-spacing: .2em;
      text-transform: uppercase;
    }

    .phase-num {
      color: var(--purple2);
      font-family: var(--sans);
      font-weight: 700;
      font-size: 1.1rem;
    }

    footer {
      border-top: 1px solid var(--border);
      padding: 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 20px;
      font-size: .6rem;
      color: var(--muted);
      letter-spacing: .15em;
    }

    .footer-logo {
      font-family: var(--sans);
      font-weight: 800;
      font-size: .9rem;
      color: var(--bright);
    }
    .footer-logo span { color: var(--purple2); }

    @keyframes fadein {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity .7s, transform .7s;
    }
    .reveal.visible {
      opacity: 1;
      transform: none;
    }

    @media (max-width: 768px) {
      nav { padding: 16px 20px; }
      .hero { padding: 100px 20px 60px; }
      .section-wrap { padding: 60px 20px; }
      .divider { margin: 0 20px; }
      footer { padding: 32px 20px; }
      .diagram-wrap { flex-direction: column; }
      .phase-row { grid-template-columns: 60px 1fr; }
      .phase-row .phase-cell:last-child { display: none; }
    }
  </style>
</head>
